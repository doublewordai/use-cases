# ----- Doubleword (the only inference key you need) -----
# Get a key: https://app.doubleword.ai
DOUBLEWORD_API_KEY=dw-...
DOUBLEWORD_BASE_URL=https://api.doubleword.ai/v1

# Models: https://docs.doubleword.ai/inference-api/model-pricing
MODEL_CHAT=deepseek-ai/DeepSeek-V4-Pro
MODEL_JUDGE=deepseek-ai/DeepSeek-V4-Pro

# Concurrency cap for eval.py.
MAX_CONCURRENCY=8

# ----- Arize Phoenix -----
PROJECT_NAME=doubleword-arize

# Local default; change if 6006 is taken.
PHOENIX_PORT=6006

# Cloud (optional): https://app.phoenix.arize.com (docs: https://docs.arize.com/phoenix)
# PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
# PHOENIX_API_KEY=...

BATCH_COMPLETION_WINDOW=24h
